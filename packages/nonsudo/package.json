{
  "name": "nonsudo",
  "version": "1.3.0",
  "description": "NonSudo — mandate enforcement and cryptographic receipts for AI agents",
  "keywords": [
    "ai-agents",
    "governance",
    "policy",
    "receipts",
    "security",
    "fintech"
  ],
  "homepage": "https://nonsudo.com",
  "bugs": {
    "url": "https://github.com/nonsudo/varcore/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonsudo/varcore.git",
    "directory": "packages/nonsudo"
  },
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./policy": {
      "types": "./dist/policy.d.ts",
      "default": "./dist/policy.js"
    },
    "./adapter-openai": {
      "types": "./dist/adapter-openai.d.ts",
      "default": "./dist/adapter-openai.js"
    },
    "./adapter-langchain": {
      "types": "./dist/adapter-langchain.d.ts",
      "default": "./dist/adapter-langchain.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "default": "./dist/store.js"
    }
  },
  "bin": {
    "nonsudo": "bin/nonsudo.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@varcore/core": "^1.2.1",
    "@varcore/receipts": "^1.2.2",
    "@varcore/policy": "^1.2.6",
    "@varcore/store": "^1.2.1",
    "@varcore/adapter-openai": "^1.2.3",
    "@varcore/adapter-langchain": "^1.2.3",
    "commander": "^12.0.0",
    "express": "^4.18.0",
    "yaml": "^2.3.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@langchain/core": ">=0.3.80"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@langchain/core": { "optional": true }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
