{
  "name": "@varcore/receipts",
  "version": "1.2.1",
  "description": "Verifiable Action Receipt (VAR) cryptographic foundation",
  "license": "Apache-2.0",
  "keywords": [
    "nonsudo",
    "receipts",
    "var",
    "verifiable",
    "signing",
    "ed25519",
    "governance",
    "audit"
  ],
  "homepage": "https://nonsudo.com",
  "bugs": {
    "url": "https://github.com/varcore-standards/varcore/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varcore-standards/varcore.git",
    "directory": "packages/receipts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@varcore/core": "^1.2.0",
    "@peculiar/asn1-cms": "^2.6.0",
    "@peculiar/asn1-schema": "^2.6.0",
    "@peculiar/asn1-tsp": "^2.6.1",
    "@peculiar/asn1-x509": "^2.6.1",
    "canonicalize": "^2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@noble/ed25519)/)"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {}
      ],
      "^.+\\.js$": [
        "ts-jest",
        {
          "tsconfig": {
            "allowJs": true
          }
        }
      ]
    }
  }
}
