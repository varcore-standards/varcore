          "type": [
            "string",
            "null"
          ]
        },
        "chain_sequence": {
          "description": "Position in the agent-class-level chain, 0-indexed.",
          "type": "number"
        },
        "issued_at": {
          "type": "string"
        },
        "mandate_id": {
          "description": "Identifier of the mandate this invocation was evaluated against.",
          "type": "string"
