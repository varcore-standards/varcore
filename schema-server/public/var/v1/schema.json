    "ApprovalReceiptFields": {
      "additionalProperties": false,
      "description": "approval_receipt — emitted when a STEP_UP decision triggers the approval engine. Chain position: immediately after the corresponding action_receipt. VAR-Money v1.0 §3.4 (Group 3 — STEP_UP approval engine).",
      "properties": {
        "action_receipt_id": {
          "description": "receipt_id of the action_receipt that triggered this approval flow.",
          "type": "string"
        },
        "agent_class_id": {
          "description": "Stable identifier for the agent class, produced by computeAgentClassId().",
          "type": "string"
